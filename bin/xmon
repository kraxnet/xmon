#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"
require "xmon"
require "slop"

begin
opts = Slop.parse do |o|
  o.banner = "Usage: xmon <command> [options]\n\nCommands: check, generate, scan, stats, validate"
  o.array '-d', '--definition', 'Definition file(s) to load (for check)'
  o.string '-i', '--inventory', 'Inventory directory with YAML files (for generate/scan)'
  o.string '-o', '--output', 'Output directory (default: output)', default: 'output'
  o.on '-v', '--version' do
    puts Xmon::VERSION
    exit
  end
  o.on '-h', '--help' do
    puts o
    exit
  end
end
rescue Slop::Error => e
  puts e
  exit
end

command = opts.arguments.first

case command
when "check"
  abort "No definition files specified. Use -d <file>" if opts[:definition].empty?
  opts[:definition].each do |file|
    Xmon.load(file).check
  end
  Xmon::Results.print

when "generate"
  abort "No inventory directory specified. Use -i <dir>" unless opts[:inventory]
  Xmon::Inventory::Page.output_dir = opts[:output]
  Xmon::Inventory::Generator.run(inventory_dir: opts[:inventory])
  puts "Generated pages in #{opts[:output]}/"

when "scan"
  Xmon::Inventory::Page.output_dir = opts[:output]
  Xmon::Inventory::Scanner.run
  puts "Scan complete."

when "stats"
  Xmon::Inventory::Page.output_dir = opts[:output]
  Xmon::Inventory::Stats.run

when "validate"
  Xmon::Inventory::Page.output_dir = opts[:output]
  Xmon::Inventory::Validator.run

else
  puts opts
  exit 1
end
